# TalkFlow Environment Configuration

# Database
POSTGRES_USER=talkflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=talkflow
# For Local Development (SQLite), DATABASE_URL is automatically handled if left blank

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=talkflow

# Model Paths (Relative to BASE_DIR unless absolute)
MODELS_PATH=./models
MUSETALK_DIR=./musetalk

# App Settings (Local paths will be resolved relative to project root)
UPLOAD_DIR=./data/uploads
PROCESSING_DIR=./data/processing
OUTPUT_DIR=./data/outputs
