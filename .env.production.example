POSTGRES_USER=talkflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=talkflow

REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=talkflow
MINIO_SECURE=False

# Engine: musetalk or sadtalker
LIPSYNC_ENGINE=musetalk

# Paths inside containers
MODELS_PATH=/app/models
UPLOAD_DIR=/app/data/uploads
PROCESSING_DIR=/app/data/processing
OUTPUT_DIR=/app/data/outputs

# To use external storage like AWS S3, set these to your actual credentials
# MINIO_ENDPOINT=s3.amazonaws.com
# MINIO_ACCESS_KEY=your_access_key
# MINIO_SECRET_KEY=your_secret_key
# MINIO_SECURE=True
